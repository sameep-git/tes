# --- Required ---
# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth (optional but strongly recommended) ---
# Shared secret that protects the AI agent endpoint.
# If set, the frontend must send Authorization: Bearer <token> with every chat request.
# Generate a strong random value: openssl rand -hex 32
TES_ADMIN_TOKEN=

# Must match TES_ADMIN_TOKEN so the frontend can authenticate against the backend
NEXT_PUBLIC_ADMIN_TOKEN=

# --- Optional (defaults shown) ---
# DATABASE_URL=sqlite:///./scheduler.db
