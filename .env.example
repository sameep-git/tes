# --- Required ---
# Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Auth (optional, server-side only) ---
# Shared secret that guards the AI agent endpoint at the network level.
# Keep this server-side ONLY — do NOT mirror it into any NEXT_PUBLIC_* variable,
# as NEXT_PUBLIC_* values are compiled into the browser bundle and visible to all clients.
# Generate a strong random value: openssl rand -hex 32
TES_ADMIN_TOKEN=

# --- Optional (defaults shown) ---
# DATABASE_URL=sqlite:///./scheduler.db
